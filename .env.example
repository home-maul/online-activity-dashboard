# NextAuth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32

# Access control — comma-separated domain(s) or email(s) allowed to log in
ALLOWED_DOMAINS=homerunner.com
# ALLOWED_EMAILS=user@example.com,another@example.com

# Google OAuth
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret

# Google Ads
GOOGLE_ADS_DEVELOPER_TOKEN=your-developer-token
GOOGLE_ADS_CUSTOMER_ID=1234567890

# Google Analytics 4
GA4_PROPERTY_ID=123456789

# Google Search Console
SEARCH_CONSOLE_SITE_URL=https://www.homerunner.com

# YouTube (optional — auto-detects channel from Google OAuth)
# YOUTUBE_CHANNEL_ID=UCxxxxxxxxxxxxxxxxxxxxxx

# LinkedIn (OAuth — get token via /api/linkedin/connect)
LINKEDIN_CLIENT_ID=your-linkedin-client-id
LINKEDIN_CLIENT_SECRET=your-linkedin-client-secret
LINKEDIN_ACCESS_TOKEN=your-linkedin-access-token
LINKEDIN_ORGANIZATION_ID=12345678
LINKEDIN_AD_ACCOUNT_ID=12345678

# AI Insights (Claude)
ANTHROPIC_API_KEY=your-anthropic-api-key

# Pipedrive CRM
PIPEDRIVE_API_TOKEN=your-api-token
PIPEDRIVE_DOMAIN=your-company-domain
# Optional: custom field keys for source/campaign tracking on deals
# Find these in Pipedrive > Settings > Data fields > Deal, or via /api/pipedrive/fields
# PIPEDRIVE_SOURCE_FIELD=40-char-hash-for-source-field
# PIPEDRIVE_CAMPAIGN_FIELD=40-char-hash-for-campaign-field
# PIPEDRIVE_UTM_MEDIUM_FIELD=40-char-hash-for-medium-field
# PIPEDRIVE_GCLID_FIELD=40-char-hash-for-gclid-field
# PIPEDRIVE_FBCLID_FIELD=40-char-hash-for-fbclid-field

# Microsoft Clarity (optional — adds behavioral session data to Prospects)
# CLARITY_PROJECT_ID=your-clarity-project-id
# CLARITY_API_TOKEN=your-clarity-api-token
